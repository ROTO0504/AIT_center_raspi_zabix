# ==============================
# Azure / Microsoft Graph
# ==============================
APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=

# 監視対象メールボックス
# me: ログインユーザー自身
# user@example.com: 指定ユーザーのメールボックス
MAILBOX_USER=me
MAIL_FOLDER=Inbox
TARGET_RECIPIENT=zabbix@aitech.ac.jp

# 監視間隔（秒）
# 常時運用なら 3〜10 秒がおすすめ
MAIL_POLL_INTERVAL=3

# 旧互換（未設定なら MAIL_POLL_INTERVAL が優先）
POLL_INTERVAL=30

# 取得件数
TEST_TOP=100
PI_TOP=50

# 実行モード: auto / mac / raspi
RUN_MODE=auto

# Public client で device flow のとき、ブラウザを自動起動するか
OPEN_BROWSER=1

# 任意: スコープを明示したい場合
# 例: Mail.Read Mail.ReadWrite
GRAPH_SCOPES=

# ==============================
# Web
# ==============================
WEB_PORT=8080

# ==============================
# Button (Raspberry Pi)
# ==============================
BUTTON_ENABLED=true
BUTTON_PIN=21
BUTTON_PULL=up
BUTTON_POLL_INTERVAL=0.1
